<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        app:cardCornerRadius="15dp"
        app:cardElevation="5dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <ImageView
                android:id="@+id/cart_img"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:contentDescription="@string/nama_makanan"
                android:scaleType="centerCrop"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:srcCompat="@tools:sample/avatars" />

            <TextView
                android:id="@+id/cart_food"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="@string/nama_makanan"
                android:textStyle="bold"
                app:layout_constraintStart_toEndOf="@id/cart_img"
                app:layout_constraintTop_toTopOf="@id/cart_img" />

            <TextView
                android:id="@+id/cart_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/harga"
                app:layout_constraintStart_toStartOf="@id/cart_food"
                app:layout_constraintTop_toBottomOf="@id/cart_food" />

            <TextView
                android:id="@+id/cart_deskripsi"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Deskripsi"
                app:layout_constraintEnd_toStartOf="@+id/plusbtn"
                app:layout_constraintStart_toStartOf="@id/cart_price"
                app:layout_constraintTop_toBottomOf="@id/cart_price" />

            <TextView
                android:id="@+id/cart_tersedia"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Tersedia"
                app:layout_constraintStart_toStartOf="@id/cart_deskripsi"
                app:layout_constraintTop_toBottomOf="@id/cart_deskripsi" />

            <ImageButton
                android:id="@+id/minbtn"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginTop="40dp"
                android:background="@drawable/add_shape"
                android:padding="2dp"
                android:src="@drawable/img_7"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@null" />

            <TextView
                android:id="@+id/cartItemQuantity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:text="1"
                app:layout_constraintBottom_toBottomOf="@id/minbtn"
                app:layout_constraintEnd_toStartOf="@id/minbtn"
                app:layout_constraintTop_toTopOf="@id/minbtn" />

            <ImageButton
                android:id="@+id/plusbtn"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/add_shape"
                android:padding="2dp"
                android:src="@drawable/img_6"
                app:layout_constraintBottom_toBottomOf="@id/cartItemQuantity"
                app:layout_constraintEnd_toStartOf="@id/cartItemQuantity"
                app:layout_constraintTop_toTopOf="@id/cartItemQuantity"
                app:tint="@null" />

            <ImageButton
                android:id="@+id/deletebtn"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/add_shape"
                android:padding="2dp"
                android:src="@drawable/img_8"
                app:tint="@null"
                app:layout_constraintEnd_toEndOf="@id/minbtn"
                app:layout_constraintStart_toStartOf="@id/plusbtn"
                app:layout_constraintTop_toBottomOf="@id/minbtn" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
